---
import { AstroSeo, type AstroSeoProps } from "@astrolib/seo";
import BaseHead from "@components/BaseHead.astro";
import Footer from "@components/global/Footer.astro";
import Navigation from "@components/global/Navigation.astro";

type Props = {
	seo?: AstroSeoProps;
};

const { seo: seoProp } = Astro.props;

const shareImage = new URL("og.png", Astro.site).toString();

const defaultSeo: AstroSeoProps = {
	title: "Notificator — Alerts that start with your WordPress events",
	description:
		"Turn WordPress events into dashboard alerts, mobile push notifications, and MQTT messages with the free, open-source Notificator plugin.",
	canonical: "https://notificator-project.com/",
	openGraph: {
		url: "https://notificator-project.com/",
		title: "Notificator — WordPress alerts, your way",
		description: "Discover site events and route the ones that matter to your dashboard, phone, or MQTT devices.",
		images: [
			{
				url: shareImage,
				width: 1734,
				height: 907,
				alt: "Notificator",
				type: "image/png",
			},
		],
		site_name: "Notificator Project",
	},
	twitter: {
		handle: "@wp_notificator",
		site: "@wp_notificator",
		cardType: "summary_large_image",
	},
	additionalMetaTags: [
		{
			name: "publisher",
			content: "Vagelis P.",
		},
	],
};

const seo = {
	...defaultSeo,
	...seoProp,
	openGraph: {
		...defaultSeo.openGraph,
		...seoProp?.openGraph,
	},
	twitter: {
		...defaultSeo.twitter,
		...seoProp?.twitter,
	},
};
---

<html lang="en">
	<head>
		<BaseHead />
		<AstroSeo {...seo} />
	</head>
	<body>
		<a class="skip-link" href="#main-content">Skip to content</a>
		<Navigation />
		<main id="main-content"><slot /></main>
		<Footer />
	</body>
</html>
