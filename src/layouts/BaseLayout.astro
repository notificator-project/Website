---
//import BlobCursorFollower from "@/components/global/BlobCursorFollower.astro";
import { AstroSeo, type AstroSeoProps } from "@astrolib/seo";
import BaseHead from "@components/BaseHead.astro";
import BackgroundTexture from "@components/global/BackgroundTexture.astro";
import Footer from "@components/global/Footer.astro";
import Navigation from "@components/global/Navigation.astro";
import { getLangFromUrl } from "../i18n/utils";

const { pathname } = Astro.url;

type Props = {
	seo?: AstroSeoProps;
};

const { seo: seoProp } = Astro.props;

const lang = getLangFromUrl(Astro.url);

const shareImage = new URL("logo.svg", Astro.site).toString();

const defaultSeo: AstroSeoProps = {
	title: "Notificator Project is the ultimate toolkit for managing notifications",
	description:
		"Notificator Project is the ultimate toolkit for managing and creating notifications for WordPress and WooCommerce websites.",
	canonical: "https://Notificator Project.com",
	openGraph: {
		url: "https://Notificator Project.com",
		title: "Notificator Project",
		description:
			"Notificator Project is the ultimate toolkit for managing and creating notifications for WordPress and WooCommerce websites.",
		images: [
			{
				url: shareImage,
				width: 1200,
				height: 630,
				alt: "Social open graph",
				type: "image/gif",
			},
			{
				url: shareImage,
				width: 4096,
				height: 4096,
				alt: "Twitter open graph",
				type: "image/gif",
			},
		],
		site_name: "Notificator Project",
	},
	twitter: {
		handle: "",
		site: "",
		cardType: "summary_large_image",
	},
	additionalMetaTags: [
		{
			name: "publisher",
			content: "Vagelis P.",
		},
	],
};

const seo = {
	...defaultSeo,
	...seoProp,
};

function cursorFollowerActive() {
	const paths = ["", "/", "/el/", "/el"];
	return paths.includes(pathname);
}
---

<html lang={lang}>
	<head>
		<BaseHead />
		<AstroSeo {...seo} />
	</head>
	<body class="bg-slate-50">
		<BackgroundTexture />
		<Navigation />
		<!-- {cursorFollowerActive() && <BlobCursorFollower />} -->
		<slot />
		<Footer />
	</body>
</html>
