---
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { AstroSeoProps } from "@astrolib/seo";
import Articles from "@components/blog/Articles.astro";

const seo: AstroSeoProps = {
	title: "Notificator Journal — Project updates and notification patterns",
	description: "Release notes, integration updates, and practical ideas from the open-source Notificator project.",
	canonical: "https://notificator-project.com/blog/",
	openGraph: {
		url: "https://notificator-project.com/blog",
		title: "Notificator Journal",
		description: "Release notes, integration updates, and practical ideas from Notificator.",
		site_name: "Notificator Project",
	},
	twitter: {
		handle: "@wp_notificator",
		site: "@wp_notificator",
		cardType: "summary_large_image",
	},
};
---

<BaseLayout seo={seo}>
	<Articles />
</BaseLayout>
