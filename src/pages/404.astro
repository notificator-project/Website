---
import Error404 from "@/components/infopages/Error404.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { AstroSeoProps } from "@astrolib/seo";

const seo: AstroSeoProps = {
	title: "404 Error: Page Not Found - Notificator Project",
	description:
		"Oops! The page you're looking for doesn't exist. Navigate back to our homepage.",
	canonical: "https://notificator-project.com/404/",
};
---

<BaseLayout seo={seo}>
	<Error404 />
</BaseLayout>
