---
import Contact from "@/components/forms/Contact.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { AstroSeoProps } from "@astrolib/seo";

const seo: AstroSeoProps = {
	title: "Contact Notificator",
	description: "Contact the Notificator project about support, integrations, contributions, or collaboration.",
	canonical: "https://notificator-project.com/contact/",
};
---

<BaseLayout seo={seo}>
	<Contact />
</BaseLayout>
