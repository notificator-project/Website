---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts"))
	.filter((post) => post.slug.startsWith("en/"))
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
	.slice(0, 3);

const integrations = [
	{ name: "WordPress Core", detail: "Users, comments, updates", icon: "W" },
	{ name: "WooCommerce", detail: "Orders and store events", icon: "WC" },
	{ name: "Form plugins", detail: "Leads and failed sends", icon: "F" },
	{ name: "Custom hooks", detail: "Your own events and payloads", icon: "{}" },
	{ name: "Mobile app", detail: "Alerts on iOS and Android", icon: "APP" },
	{ name: "Notificator devices", detail: "Dedicated displays and printers", icon: "IoT" },
];
---

<section class="hero section-space">
	<div class="site-shell hero-grid">
		<div class="hero-copy">
			<p class="eyebrow">Notificator 1.1 · Public release</p>
			<h1 class="display-title">Your WordPress site, finally speaking up.</h1>
			<p class="hero-intro">
				Discover the events that matter and turn them into dashboard alerts, mobile push notifications, or MQTT messages—without writing a
				monitoring system.
			</p>
			<div class="hero-actions">
				<a class="button button-primary" href="#ecosystem">Explore the ecosystem <span aria-hidden="true">↓</span></a>
				<a class="button button-secondary" href="#how-it-works">See how it works <span aria-hidden="true">↓</span></a>
			</div>
			<ul class="hero-proof" aria-label="Notificator highlights">
				<li><span>✓</span> Free and open source</li>
				<li><span>✓</span> Local alerts need no account</li>
				<li><span>✓</span> Built for real WordPress events</li>
			</ul>
		</div>

		<div class="platform-preview" aria-label="Preview of the Notificator WordPress dashboard">
			<div class="stage-glow"></div>
			<div class="dashboard-window">
				<div class="window-bar">
					<div class="window-dots"><span></span><span></span><span></span></div>
					<span>Notificator / Overview</span>
					<span class="window-live"><i></i> Live</span>
				</div>
				<div class="dashboard-body">
					<aside class="dashboard-nav">
						<span class="mini-brand">N</span>
						<span class="nav-line active"></span>
						<span class="nav-line"></span>
						<span class="nav-line short"></span>
					</aside>
					<div class="dashboard-main">
						<div class="dashboard-heading">
							<div><small>Good afternoon</small><strong>Your site is listening.</strong></div>
							<span>+ Create notification</span>
						</div>
						<div class="health-grid">
							<div><small>Active alerts</small><strong>12</strong><em>+2 this week</em></div>
							<div><small>Events today</small><strong>148</strong><em>All systems normal</em></div>
							<div><small>Delivery health</small><strong>99.9%</strong><em>Healthy</em></div>
						</div>
						<div class="activity-card">
							<div class="activity-title"><strong>Recent events</strong><span>View activity</span></div>
							<div class="activity-row">
								<i class="order">WC</i><span><strong>New WooCommerce order</strong><small>Order #1048 · €84.00</small></span><time>
									Now
								</time>
							</div>
							<div class="activity-row">
								<i class="user">U</i><span><strong>New user registered</strong><small>Customer account created</small></span><time>
									4m
								</time>
							</div>
							<div class="activity-row">
								<i class="form">F</i><span>
									<strong>Form submission received</strong><small>Contact form · Website lead</small>
								</span><time>11m</time>
							</div>
						</div>
					</div>
				</div>
			</div>

			<div class="phone-alert">
				<div class="phone-top"><span>9:41</span><i></i></div>
				<div class="phone-app"><span class="app-icon">N</span><strong>NOTIFICATOR</strong><time>now</time></div>
				<p>New order received</p>
				<small>Order #1048 is ready for review.</small>
			</div>
		</div>
	</div>
</section>

<section id="how-it-works" class="section-space how-it-works-section">
	<div class="site-shell">
		<div class="section-heading split-heading">
			<div>
				<p class="eyebrow">From event to action</p>
				<h2 class="section-title">One clear path from WordPress to wherever you are.</h2>
			</div>
			<p class="section-copy">
				Notificator separates discovery, configuration, and delivery so you always understand what the plugin is listening for—and where each
				alert will go.
			</p>
		</div>

		<div id="channels" class="flow-board">
			<div class="flow-source flow-card">
				<span class="flow-index">01</span>
				<div class="flow-icon wordpress">W</div>
				<small>Source</small>
				<strong>A WordPress event happens</strong>
				<p>An order arrives, a form fails, a user signs in, or your own code fires a hook.</p>
			</div>
			<div class="flow-connector"><span></span><i>Event</i></div>
			<div class="flow-center flow-card">
				<span class="flow-index">02</span>
				<div class="flow-icon notificator">N</div>
				<small>Notificator</small>
				<strong>Your rule decides what matters</strong>
				<p>Apply conditions, render useful details, set priority, and control throttling.</p>
			</div>
			<div class="flow-connector"><span></span><i>Alert</i></div>
			<div class="flow-destinations flow-card">
				<span class="flow-index">03</span>
				<small>Destinations</small>
				<strong>Deliver it your way</strong>
				<div class="channel-list">
					<span><b>D</b> WordPress dashboard</span>
					<span><b>P</b> iOS &amp; Android app</span>
					<span><b>N</b> Notificator devices</span>
				</div>
			</div>
		</div>
	</div>
</section>

<section class="section-space feature-section">
	<div class="site-shell feature-layout">
		<div class="feature-copy">
			<p class="eyebrow">Built for WordPress</p>
			<h2 class="section-title">Start locally. Add remote delivery when you need it.</h2>
			<p class="section-copy">
				Scan installed plugins, choose from ready-made templates, or register events directly from your own code. Dashboard alerts work
				immediately—no API key required.
			</p>
			<div class="feature-points">
				<div><span>01</span><p><strong>Discover</strong>Find useful hooks with confidence, risk, and plain-language descriptions.</p></div>
				<div><span>02</span><p><strong>Configure</strong>Build readable notifications with conditions, placeholders, and priorities.</p></div>
				<div><span>03</span><p><strong>Reuse</strong>Export your setup and import it on another WordPress site.</p></div>
			</div>
		</div>

		<div class="builder-card">
			<div class="builder-top"><span>Create notification</span><small>Step 3 of 3</small></div>
			<div class="builder-steps"><span class="done">1</span><i></i><span class="done">2</span><i></i><span class="active">3</span></div>
			<label>Notification name<input type="text" value="New order needs attention" readonly /></label>
			<label>Message<textarea rows="3" readonly set:text={"Order #{{order_id}} was placed for {{order_total}}."} /></label>
			<div class="delivery-label">Deliver to</div>
			<div class="delivery-options">
				<span class="selected"><i>✓</i> Dashboard</span>
				<span class="selected"><i>✓</i> Mobile app</span>
				<span><i></i> Devices</span>
			</div>
			<div class="builder-footer"><small>woocommerce_new_order</small><button type="button">Save notification</button></div>
		</div>
	</div>
</section>

<section id="ecosystem" class="section-space ecosystem-section">
	<div class="site-shell">
		<div class="section-heading split-heading">
			<div>
				<p class="eyebrow">One connected ecosystem</p>
				<h2 class="section-title">See the alert where it is most useful.</h2>
			</div>
			<p class="section-copy">
				Start with notifications inside WordPress, then connect the Notificator mobile app or a dedicated Notificator device whenever your
				workflow needs to move beyond the dashboard.
			</p>
		</div>

		<div class="ecosystem-grid">
			<article>
				<span class="ecosystem-label">Included</span>
				<div class="ecosystem-icon">WP</div>
				<h3>Dashboard alerts</h3>
				<p>Review important events directly in WordPress. No Notificator account or API key is required.</p>
			</article>
			<article class="featured">
				<span class="ecosystem-label">iOS + Android</span>
				<div class="ecosystem-icon">APP</div>
				<h3>Notificator mobile app</h3>
				<p>Create your Notificator account in the mobile app and receive push alerts wherever you are.</p>
			</article>
			<article>
				<span class="ecosystem-label">Physical</span>
				<div class="ecosystem-icon">IoT</div>
				<h3>Notificator devices</h3>
				<p>Route selected alerts to dedicated displays, printers, and other compatible Notificator devices.</p>
			</article>
		</div>
	</div>
</section>

<section id="integrations" class="section-space integrations-section">
	<div class="site-shell">
		<p class="eyebrow">Ready to connect</p>
		<h2 class="section-title">Useful integrations without the setup headache.</h2>
		<p class="section-copy">
			Start with curated templates, discover events from installed plugins, or publish a first-class Notificator integration from your own
			plugin.
		</p>

		<div class="integration-grid">
			{
				integrations.map((integration) => (
					<article>
						<span>{integration.icon}</span>
						<div>
							<>
								<h3>{integration.name}</h3>
								<p>{integration.detail}</p>
							</>
						</div>
						<i aria-hidden="true">↗</i>
					</article>
				))
			}
		</div>

		<div class="developer-strip">
			<div>
				<span class="code-mark">&lt;/&gt;</span><div>
					<strong>Building a plugin?</strong><p>Register documented events and ready-made templates through the public integration API.</p>
				</div>
			</div>
			<a class="button button-secondary" href="https://docs.notificator-project.com/" target="_blank" rel="noreferrer">
				Read developer docs ↗
			</a>
		</div>
	</div>
</section>

<section class="section-space open-source-section">
	<div class="site-shell open-source-card">
		<div>
			<p class="eyebrow">Open by default</p>
			<h2 class="section-title">Free, open source, and built to remain useful.</h2>
			<p class="section-copy">
				Notificator’s current features stay free. Inspect the code, build an integration, report an issue, or support continued development.
			</p>
			<div class="open-actions">
				<a class="button button-primary" href="https://github.com/notificator-project/WordPress-Plugin" target="_blank" rel="noreferrer">
					View on GitHub ↗
				</a>
				<a class="button dark-secondary" href="https://buymeacoffee.com/vagelis" target="_blank" rel="noreferrer">Support the project</a>
			</div>
		</div>
		<div class="repo-card">
			<div class="repo-head">
				<span class="repo-icon">N</span><div><small>notificator-project</small><strong>WordPress-Plugin</strong></div><i>Public</i>
			</div>
			<p>Alerts and notifications driven by meaningful WordPress events.</p>
			<div class="repo-code">
				<span><i class="php"></i>PHP</span><span><i class="ts"></i>TypeScript</span><span><i class="scss"></i>SCSS</span>
			</div>
			<div class="repo-meta"><span>GPL-3.0</span><span>Version 1.1</span></div>
		</div>
	</div>
</section>

{
	posts.length > 0 && (
		<section class="section-space journal-section">
			<div class="site-shell">
				<div class="journal-heading">
					<div>
						<>
							<p class="eyebrow">From the journal</p>
							<h2 class="section-title">Updates from the project.</h2>
						</>
					</div>
					<a href="/blog/">
						View every post <span>→</span>
					</a>
				</div>
				<div class="journal-grid">
					{posts.map((post) => {
						const slug = post.slug.replace(/^en\//, "");
						return (
							<a class="journal-card" href={`/blog/${slug}/`}>
								<div class="journal-image">
									<Image src={post.data.image.source} alt={post.data.image.alt || post.data.title} />
								</div>
								<time datetime={post.data.pubDate.toISOString()}>
									{post.data.pubDate.toLocaleDateString("en", { day: "numeric", month: "short", year: "numeric" })}
								</time>
								<h3>{post.data.title}</h3>
								<p>{post.data.description}</p>
								<span>Read article →</span>
							</a>
						);
					})}
				</div>
			</div>
		</section>
	)
}

<section class="final-cta">
	<div class="site-shell final-cta-card">
		<div><p class="eyebrow">Ready when your site is</p><h2>Turn the events that matter into alerts you can act on.</h2></div>
		<div class="final-actions">
			<a class="button button-primary" href="https://docs.notificator-project.com/" target="_blank" rel="noreferrer">
				Read the documentation ↗
			</a>
			<a href="https://github.com/notificator-project/WordPress-Plugin" target="_blank" rel="noreferrer">View the project on GitHub →</a>
		</div>
	</div>
</section>

<style>
	.hero {
		padding-top: clamp(70px, 8vw, 112px);
		overflow: hidden;
	}

	.hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(540px, 1.1fr);
		gap: clamp(40px, 6vw, 90px);
		align-items: center;
	}

	.hero-intro {
		max-width: 650px;
		margin: 28px 0 0;
		font-size: clamp(1.08rem, 1.8vw, 1.3rem);
		line-height: 1.65;
		color: var(--ink-soft);
	}

	.hero-actions,
	.open-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 34px;
	}

	.hero-proof {
		display: flex;
		flex-wrap: wrap;
		gap: 10px 20px;
		margin: 30px 0 0;
		padding: 0;
		list-style: none;
		font-size: 0.78rem;
		font-weight: 650;
		color: #59627a;
	}

	.hero-proof li {
		display: flex;
		align-items: center;
		gap: 6px;
	}

	.hero-proof span {
		color: var(--success);
	}

	.platform-preview {
		position: relative;
		min-height: 550px;
	}

	.stage-glow {
		position: absolute;
		inset: 7% -10% -4% 12%;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(60, 120, 255, 0.32), rgba(60, 120, 255, 0));
		filter: blur(30px);
	}

	.dashboard-window {
		position: absolute;
		top: 20px;
		right: -70px;
		width: 690px;
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.72);
		border-radius: 25px;
		background: #eef2f8;
		box-shadow: 0 40px 100px rgba(21, 38, 81, 0.22);
		transform: perspective(1200px) rotateY(-5deg) rotateX(2deg);
	}

	.window-bar {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		border-bottom: 1px solid #dfe5ef;
		background: white;
		padding: 13px 16px;
		font-size: 0.67rem;
		font-weight: 650;
		color: #6a738a;
	}

	.window-dots {
		display: flex;
		gap: 5px;
	}

	.window-dots span {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: #d6dce7;
	}

	.window-live {
		justify-self: end;
		color: var(--success);
	}

	.window-live i {
		display: inline-block;
		width: 6px;
		height: 6px;
		margin-right: 4px;
		border-radius: 50%;
		background: currentColor;
	}

	.dashboard-body {
		display: grid;
		grid-template-columns: 68px 1fr;
		min-height: 430px;
	}

	.dashboard-nav {
		display: flex;
		align-items: center;
		flex-direction: column;
		gap: 19px;
		background: #10172b;
		padding: 20px 12px;
	}

	.mini-brand {
		display: grid;
		width: 30px;
		height: 30px;
		place-items: center;
		margin-bottom: 10px;
		border-radius: 9px;
		background: var(--blue);
		font-size: 0.7rem;
		font-weight: 800;
		color: white;
	}

	.nav-line {
		width: 29px;
		height: 5px;
		border-radius: 4px;
		background: #30394f;
	}

	.nav-line.short {
		width: 20px;
	}

	.nav-line.active {
		background: #5e8bff;
	}

	.dashboard-main {
		padding: 27px;
	}

	.dashboard-heading {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.dashboard-heading div {
		display: flex;
		align-items: flex-start;
		flex-direction: column;
	}

	.dashboard-heading small {
		font-size: 0.63rem;
		color: #7b849a;
	}

	.dashboard-heading strong {
		font-size: 1.15rem;
		letter-spacing: -0.035em;
	}

	.dashboard-heading > span {
		border-radius: 8px;
		background: var(--blue);
		padding: 8px 11px;
		font-size: 0.58rem;
		font-weight: 700;
		color: white;
	}

	.health-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 10px;
		margin-top: 24px;
	}

	.health-grid div {
		display: flex;
		align-items: flex-start;
		flex-direction: column;
		border: 1px solid #e0e5ee;
		border-radius: 13px;
		background: white;
		padding: 14px;
	}

	.health-grid small,
	.activity-row small {
		font-size: 0.55rem;
		color: #7b849a;
	}

	.health-grid strong {
		margin-top: 6px;
		font-size: 1.25rem;
	}

	.health-grid em {
		margin-top: 5px;
		font-size: 0.48rem;
		font-style: normal;
		color: var(--success);
	}

	.activity-card {
		margin-top: 12px;
		border: 1px solid #e0e5ee;
		border-radius: 14px;
		background: white;
		padding: 15px;
	}

	.activity-title,
	.activity-row {
		display: flex;
		align-items: center;
	}

	.activity-title {
		justify-content: space-between;
		padding-bottom: 10px;
		font-size: 0.63rem;
	}

	.activity-title span {
		color: var(--blue);
	}

	.activity-row {
		gap: 10px;
		border-top: 1px solid #edf0f5;
		padding: 10px 0;
	}

	.activity-row > i {
		display: grid;
		width: 28px;
		height: 28px;
		flex: 0 0 auto;
		place-items: center;
		border-radius: 8px;
		background: #eaf0ff;
		font-size: 0.48rem;
		font-style: normal;
		font-weight: 800;
		color: var(--blue);
	}

	.activity-row > span {
		display: flex;
		min-width: 0;
		flex: 1;
		align-items: flex-start;
		flex-direction: column;
		gap: 2px;
	}

	.activity-row strong {
		font-size: 0.61rem;
	}

	.activity-row time {
		font-size: 0.52rem;
		color: #8a93a8;
	}

	.phone-alert {
		position: absolute;
		right: -5px;
		bottom: 22px;
		width: 258px;
		border: 7px solid #111727;
		border-radius: 32px;
		background: rgba(255, 255, 255, 0.96);
		box-shadow: 0 28px 70px rgba(14, 24, 53, 0.3);
		padding: 15px 17px 22px;
		transform: rotate(2deg);
	}

	.phone-top,
	.phone-app {
		display: flex;
		align-items: center;
	}

	.phone-top {
		justify-content: space-between;
		font-size: 0.55rem;
		font-weight: 700;
	}

	.phone-top i {
		width: 60px;
		height: 15px;
		border-radius: 10px;
		background: #111727;
	}

	.phone-app {
		gap: 7px;
		margin-top: 21px;
		font-size: 0.54rem;
	}

	.phone-app time {
		margin-left: auto;
		color: #8891a5;
	}

	.app-icon {
		display: grid;
		width: 24px;
		height: 24px;
		place-items: center;
		border-radius: 7px;
		background: var(--blue);
		font-weight: 800;
		color: white;
	}

	.phone-alert p {
		margin: 15px 0 3px;
		font-size: 0.85rem;
		font-weight: 750;
	}

	.phone-alert > small {
		font-size: 0.68rem;
		color: #667088;
	}

	.how-it-works-section {
		background: white;
	}

	.split-heading {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(300px, 0.58fr);
		gap: 60px;
		align-items: end;
	}

	.split-heading .section-copy {
		margin: 0;
	}

	.flow-board {
		display: grid;
		grid-template-columns: 1fr 90px 1fr 90px 1fr;
		align-items: stretch;
		margin-top: 58px;
	}

	.flow-card {
		position: relative;
		min-height: 320px;
		border: 1px solid var(--line);
		border-radius: 24px;
		background: #f9faff;
		padding: 30px;
	}

	.flow-center {
		border-color: #b9caff;
		background: linear-gradient(155deg, #f2f6ff, #e5edff);
		box-shadow: 0 22px 50px rgba(37, 94, 232, 0.12);
	}

	.flow-index {
		position: absolute;
		top: 20px;
		right: 22px;
		font-family: "JetBrains Mono", monospace;
		font-size: 0.68rem;
		color: #929bad;
	}

	.flow-icon {
		display: grid;
		width: 54px;
		height: 54px;
		place-items: center;
		margin-bottom: 44px;
		border-radius: 17px;
		font-size: 0.9rem;
		font-weight: 800;
	}

	.flow-icon.wordpress {
		background: #e8ecf3;
		color: #1d273a;
	}

