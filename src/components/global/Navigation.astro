---
const { pathname } = Astro.url;

const links = [
	{ label: "How it works", href: "/#how-it-works" },
	{ label: "Integrations", href: "/#integrations" },
	{ label: "Blog", href: "/blog/" },
	{ label: "Support", href: "/support/" },
	{ label: "Contact", href: "/contact/" },
	// { label: "Docs", href: "https://docs.notificator-project.com/", external: true },
];
---

<header class="site-header">
	<div class="site-shell header-inner">
		<a class="brand" href="/" aria-label="Notificator home">
			<img src="/notificator-icon.png" alt="" aria-hidden="true" />
			<span>Notificator</span>
		</a>

		<button class="menu-toggle" type="button" aria-label="Toggle navigation" aria-expanded="false" aria-controls="primary-navigation">
			<span aria-hidden="true"></span><span aria-hidden="true"></span>
		</button>

		<nav id="primary-navigation" class="primary-navigation" aria-label="Primary navigation">
			<ul>
				{
					links.map((link) => (
						<li>
							<a
								href={link.href}
								class:list={[pathname.startsWith(link.href) && link.href !== "/#how-it-works" && "active"]}
								target={link.external ? "_blank" : undefined}
								rel={link.external ? "noreferrer" : undefined}>
								{link.label}
							</a>
						</li>
					))
				}
			</ul>
		</nav>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		padding: 14px 0;
		background: linear-gradient(180deg, rgba(245, 247, 251, 0.6), rgba(245, 247, 251, 0.12));
		-webkit-backdrop-filter: blur(12px) saturate(140%);
		backdrop-filter: blur(12px) saturate(140%);
	}

	.header-inner {
		position: relative;
		isolation: isolate;
		display: flex;
		min-height: 64px;
		align-items: center;
		justify-content: space-between;
		border: 0;
		border-radius: 18px;
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.68), rgba(236, 243, 255, 0.34));
		/* box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.9),
			inset 0 -1px 0 rgba(145, 170, 221, 0.16),
			0 12px 36px rgba(26, 42, 80, 0.1),
			0 2px 8px rgba(37, 94, 232, 0.05); */
		padding: 8px 10px 8px 18px;
		-webkit-backdrop-filter: blur(24px) saturate(185%);
		backdrop-filter: blur(24px) saturate(185%);
	}

	.header-inner::before {
		position: absolute;
		z-index: -1;
		inset: 1px;
		border-radius: 17px;
		background:
			radial-gradient(circle at 12% -30%, rgba(255, 255, 255, 0.95), transparent 36%),
			radial-gradient(circle at 82% 140%, rgba(63, 124, 255, 0.17), transparent 42%),
			linear-gradient(105deg, rgba(255, 255, 255, 0.22), transparent 48%);
		content: "";
		pointer-events: none;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		font-size: 1.05rem;
		font-weight: 760;
		letter-spacing: -0.025em;
	}

	.brand img {
		display: block;
		width: 36px;
		height: 36px;
		object-fit: contain;
	}

	.primary-navigation,
	.primary-navigation ul {
		display: flex;
		align-items: center;
	}

	.primary-navigation {
		gap: 8px;
	}

	.primary-navigation ul {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.primary-navigation ul a {
		display: inline-flex;
		border-radius: 10px;
		padding: 10px 13px;
		font-size: 0.88rem;
		font-weight: 650;
		color: #4d5670;
		transition: 150ms ease;
	}

	.primary-navigation ul a:hover,
	.primary-navigation ul a.active {
		background: rgba(255, 255, 255, 0.56);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.8),
			0 4px 14px rgba(37, 94, 232, 0.08);
		color: #0b1020;
	}

	.menu-toggle {
		display: none;
		width: 42px;
		height: 42px;
		align-items: center;
		justify-content: center;
		flex-direction: column;
		gap: 6px;
		border: 0;
		border-radius: 11px;
		background: rgba(255, 255, 255, 0.5);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.85);
		cursor: pointer;
	}

	.menu-toggle span {
		width: 18px;
		height: 2px;
		border-radius: 2px;
		background: #0b1020;
		transition: transform 160ms ease;
	}

	.menu-toggle[aria-expanded="true"] span:first-child {
		transform: translateY(4px) rotate(45deg);
	}

	.menu-toggle[aria-expanded="true"] span:last-child {
		transform: translateY(-4px) rotate(-45deg);
	}

	.menu-toggle:focus-visible {
		outline: 2px solid var(--blue);
		outline-offset: 2px;
	}

	@media (max-width: 820px) {
		.site-header {
			padding: 8px 0;
		}

		.header-inner {
			position: relative;
			min-height: 58px;
		}

		.menu-toggle {
			display: flex;
		}

		.primary-navigation {
			position: absolute;
			top: calc(100% + 10px);
			left: 0;
			display: none;
			width: 100%;
			align-items: stretch;
			border: 1px solid rgba(255, 255, 255, 0.78);
			border-radius: 18px;
			background: rgba(250, 252, 255, 0.9);
			box-shadow:
				inset 0 1px 0 rgba(255, 255, 255, 0.9),
				0 20px 50px rgba(26, 42, 80, 0.14);
			padding: 12px;
			-webkit-backdrop-filter: blur(24px) saturate(170%);
			backdrop-filter: blur(24px) saturate(170%);
		}

		.primary-navigation.open {
			display: block;
		}

		.primary-navigation ul {
			align-items: stretch;
			flex-direction: column;
		}

		.primary-navigation ul a {
			width: 100%;
			justify-content: center;
		}
	}
</style>

<script>
	const toggle = document.querySelector<HTMLButtonElement>(".menu-toggle");
	const navigation = document.querySelector<HTMLElement>("#primary-navigation");

	toggle?.addEventListener("click", () => {
		const isOpen = toggle.getAttribute("aria-expanded") === "true";
		toggle.setAttribute("aria-expanded", String(!isOpen));
		navigation?.classList.toggle("open", !isOpen);
	});

	navigation?.querySelectorAll("a").forEach((link) => {
		link.addEventListener("click", () => {
			toggle?.setAttribute("aria-expanded", "false");
			navigation.classList.remove("open");
		});
	});
</script>
