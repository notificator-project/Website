---
import Newsletter from "@components/blog/Newsletter.astro";

const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="site-shell footer-card">
		<div class="footer-lead">
			<a class="footer-brand" href="/" aria-label="Notificator home">
				<img src="/notificator-icon-on-dark.png" alt="" aria-hidden="true" />
				<span>Notificator</span>
			</a>
			<p>Turn meaningful WordPress events into alerts you can act on.</p>
			<Newsletter />
		</div>

		<div class="footer-links">
			<div>
				<h2>Explore</h2>
				<a href="/#how-it-works">How it works</a>
				<a href="/#channels">Delivery channels</a>
				<a href="/#integrations">Integrations</a>
			</div>
			<div>
				<h2>Resources</h2>
				<a href="https://docs.notificator-project.com/">Documentation</a>
				<a href="/blog/">Blog</a>
				<a href="https://github.com/notificator-project">GitHub</a>
				<a href="https://x.com/WP_Notificator" target="_blank" rel="noreferrer">X / Twitter</a>
				<a href="https://www.youtube.com/@NotificatorProject" target="_blank" rel="noreferrer">YouTube</a>
			</div>
			<div>
				<h2>Project</h2>
				<a href="/contact/">Contact</a>
				<a href="https://buymeacoffee.com/vagelis">Donate</a>
				<a href="https://github.com/sponsors/vagelisp">Sponsor</a>
			</div>
		</div>

		<div class="footer-bottom">
			<span>© {year} Notificator Project</span>
			<span>Free and open source</span>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		padding: 30px 0 36px;
	}

	.footer-card {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
		gap: 70px;
		border-radius: 30px;
		background: #0b1020;
		padding: clamp(34px, 6vw, 70px);
		color: white;
	}

	.footer-lead p {
		max-width: 440px;
		margin: 28px 0 0;
		font-size: clamp(1.35rem, 2.5vw, 2.15rem);
		font-weight: 650;
		letter-spacing: -0.035em;
		line-height: 1.18;
		color: #dce4fa;
	}

	.footer-brand {
		display: inline-flex;
		align-items: center;
		gap: 11px;
		font-size: 1rem;
		font-weight: 750;
		color: white;
	}

	.footer-brand img {
		display: block;
		width: 42px;
		height: 42px;
		object-fit: contain;
	}

	.footer-lead :global(.newsletter-form) {
		margin-top: 34px;
	}

	.footer-links {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 28px;
	}

	.footer-links div {
		display: flex;
		align-items: flex-start;
		flex-direction: column;
		gap: 11px;
	}

	.footer-links h2 {
		margin: 0 0 6px;
		font-family: "JetBrains Mono", monospace;
		font-size: 0.72rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #7f8baa;
	}

	.footer-links a {
		font-size: 0.9rem;
		color: #dce4fa;
	}

	.footer-links a:hover {
		color: white;
	}

	.footer-bottom {
		display: flex;
		grid-column: 1 / -1;
		justify-content: space-between;
		border-top: 1px solid rgba(255, 255, 255, 0.12);
		padding-top: 24px;
		font-size: 0.78rem;
		color: #8792ad;
	}

	@media (max-width: 820px) {
		.footer-card {
			grid-template-columns: 1fr;
			gap: 52px;
		}
	}

	@media (max-width: 560px) {
		.footer-links {
			grid-template-columns: 1fr 1fr;
		}

		.footer-bottom {
			align-items: flex-start;
			flex-direction: column;
			gap: 8px;
		}
	}
</style>
