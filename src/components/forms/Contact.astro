<section class="contact-page section-space">
	<div class="site-shell contact-layout">
		<div class="contact-copy">
			<p class="eyebrow">Talk to the project</p>
			<h1 class="display-title">Questions, ideas, or a useful integration?</h1>
			<p>
				Tell us what you are building, report a problem, or ask how Notificator could fit your workflow. For reproducible plugin bugs, GitHub
				Issues is usually the fastest route.
			</p>
			<div class="contact-options">
				<a href="https://github.com/notificator-project/WordPress-Plugin/issues" target="_blank" rel="noreferrer">
					<span>GH</span><div><strong>GitHub Issues</strong><small>Bug reports and feature requests</small></div><i>↗</i>
				</a>
				<a href="mailto:hello@notificator-project.com">
					<span>@</span><div><strong>Email</strong><small>hello@notificator-project.com</small></div><i>↗</i>
				</a>
			</div>
		</div>

		<form name="contact" method="POST" action="/contact/" data-netlify="true" class="contact-form">
			<input type="hidden" name="form-name" value="contact" />
			<div class="form-heading"><strong>Send a message</strong><small>We usually reply within a few days.</small></div>
			<label>Name <input type="text" name="name" autocomplete="name" required /></label>
			<label>Email <input type="email" name="email" autocomplete="email" required /></label>
			<label>Company or project <input type="text" name="company" autocomplete="organization" /></label>
			<label>Message <textarea name="message" rows="6" required></textarea></label>
			<p>By sending this, you agree to our privacy practices. Do not include API keys, access tokens, passwords, or other secrets.</p>
			<div class="form-status" data-form-status role="status" aria-live="polite" aria-atomic="true" hidden></div>
			<button class="button button-primary" type="submit">Send message →</button>
		</form>
	</div>
</section>

<style>
	.contact-page {
		padding-top: clamp(70px, 8vw, 110px);
	}

	.contact-layout {
		display: grid;
		grid-template-columns: minmax(0, 0.85fr) minmax(440px, 0.65fr);
		gap: clamp(60px, 9vw, 130px);
		align-items: start;
	}

	.contact-copy > p:not(.eyebrow) {
		max-width: 650px;
		margin: 28px 0 0;
		font-size: 1.05rem;
		line-height: 1.7;
		color: var(--ink-soft);
	}

	.contact-options {
		display: grid;
		gap: 10px;
		margin-top: 40px;
	}

	.contact-options a {
		display: flex;
		align-items: center;
		gap: 13px;
		border: 1px solid var(--line);
		border-radius: 16px;
		background: rgba(255, 255, 255, 0.7);
		padding: 15px;
	}

	.contact-options a > span {
		display: grid;
		width: 42px;
		height: 42px;
		place-items: center;
		border-radius: 12px;
		background: var(--blue-pale);
		font-family: "JetBrains Mono", monospace;
		font-size: 0.7rem;
		font-weight: 700;
		color: var(--blue);
	}

	.contact-options div {
		display: flex;
		align-items: flex-start;
		flex-direction: column;
	}

	.contact-options strong {
		font-size: 0.86rem;
	}

	.contact-options small {
		font-size: 0.7rem;
		color: #748097;
	}

	.contact-options i {
		margin-left: auto;
		font-style: normal;
		color: #9aa4b7;
	}

	.contact-form {
		border: 1px solid var(--line);
		border-radius: 24px;
		background: white;
		box-shadow: var(--shadow-soft);
		padding: clamp(24px, 4vw, 38px);
	}

	.form-heading {
		display: flex;
		align-items: flex-start;
		flex-direction: column;
		margin-bottom: 24px;
	}

	.form-heading strong {
		font-size: 1.15rem;
		letter-spacing: -0.03em;
	}

	.form-heading small {
		margin-top: 4px;
		color: #7c869a;
	}

	.contact-form label {
		display: flex;
		flex-direction: column;
		gap: 7px;
		margin-top: 17px;
		font-size: 0.72rem;
		font-weight: 700;
		color: #49536b;
	}

	.contact-form input,
	.contact-form textarea {
		width: 100%;
		resize: vertical;
		border: 1px solid #d9e0eb;
		border-radius: 12px;
		background: #fafbfe;
		padding: 12px 14px;
		font-size: 0.9rem;
		color: var(--ink);
		outline: none;
	}

	.contact-form input:focus,
	.contact-form textarea:focus {
		border-color: #8eaaff;
		box-shadow: 0 0 0 3px rgba(37, 94, 232, 0.1);
	}

	.contact-form > p {
		margin: 15px 0 0;
		font-size: 0.65rem;
		color: #7c869a;
	}

	.contact-form button {
		width: 100%;
		margin-top: 22px;
		border: 0;
	}

	.contact-form button:disabled {
		cursor: wait;
		opacity: 0.7;
	}

	.form-status {
		display: grid;
		grid-template-columns: 34px minmax(0, 1fr);
		align-items: center;
		gap: 11px;
		margin-top: 18px;
		border: 1px solid transparent;
		border-radius: 14px;
		padding: 13px 14px;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.7);
		font-size: 0.76rem;
		font-weight: 650;
		line-height: 1.5;
	}

	.form-status::before {
		display: grid;
		width: 30px;
		height: 30px;
		place-items: center;
		border-radius: 10px;
		font-size: 0.82rem;
		font-weight: 800;
	}

	.form-status[hidden] {
		display: none;
	}

	.contact-form[data-form-state="success"] .form-status {
		border-color: #bfe9d4;
		background: linear-gradient(135deg, #f1fbf6, #e4f8ee);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.88),
			0 10px 24px rgba(16, 135, 82, 0.08);
		color: #086b42;
	}

	.contact-form[data-form-state="success"] .form-status::before {
		background: #15945d;
		color: white;
		content: "✓";
	}

	.contact-form[data-form-state="error"] .form-status {
		border-color: #f1cccc;
		background: linear-gradient(135deg, #fff7f7, #ffeded);
		color: #922525;
	}

	.contact-form[data-form-state="error"] .form-status::before {
		background: #c84949;
		color: white;
		content: "!";
	}

	@media (max-width: 900px) {
		.contact-layout {
			grid-template-columns: 1fr;
		}
	}
</style>

<script>
	import { enhanceNetlifyForm } from "./netlify-form";

	enhanceNetlifyForm(document.querySelector<HTMLFormElement>(".contact-form"), {
		pending: "Sending…",
		success: "Thanks — your message has been sent. We’ll get back to you soon.",
		error: "We couldn’t send your message right now. Please try again or email hello@notificator-project.com.",
	});
</script>
