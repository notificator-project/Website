---
import { getCollection } from "astro:content";
import Entry from "@/components/blog/Entry.astro";

const allPosts = (await getCollection("posts"))
	.filter((post) => post.slug.startsWith("en/"))
	.map((post) => ({ ...post, slug: post.slug.split("/").slice(1).join("/") }))
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const [featured, ...articles] = allPosts;
---

<section class="blog-index section-space">
	<div class="site-shell">
		<header class="blog-hero">
			<div>
				<p class="eyebrow">Project journal</p>
				<h1 class="display-title">Ideas, releases, and the work behind Notificator.</h1>
			</div>
			<p>
				Release notes, practical notification patterns, integration updates, and occasional dispatches from building an open-source platform.
			</p>
		</header>

		{
			featured && (
				<div class="featured-post">
					<Entry
						url={`/blog/${featured.slug}/`}
						title={featured.data.title}
						description={featured.data.description}
						pubDate={featured.data.pubDate.toISOString()}
						author={featured.data.author}
						image={featured.data.image.source}
						featured={true}
					/>
				</div>
			)
		}

		<div class="articles-heading"><h2>All stories</h2><span>{allPosts.length} articles</span></div>
		<div class="article-grid">
			{
				articles.map((post) => (
					<Entry
						url={`/blog/${post.slug}/`}
						title={post.data.title}
						description={post.data.description}
						pubDate={post.data.pubDate.toISOString()}
						author={post.data.author}
						image={post.data.image.source}
					/>
				))
			}
		</div>
	</div>
</section>

<style>
	.blog-index {
		padding-top: clamp(70px, 8vw, 110px);
	}

	.blog-hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(300px, 0.45fr);
		gap: 60px;
		align-items: end;
	}

	.blog-hero .display-title {
		max-width: 800px;
		font-size: clamp(2.8rem, 5.5vw, 5.3rem);
	}

	.blog-hero > p {
		margin: 0 0 8px;
		font-size: 1rem;
		line-height: 1.7;
		color: var(--ink-soft);
	}

	.featured-post {
		margin-top: 64px;
	}

	.articles-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		margin-top: 78px;
		border-bottom: 1px solid var(--line);
		padding-bottom: 16px;
	}

	.articles-heading h2 {
		margin: 0;
		font-size: 1.45rem;
		letter-spacing: -0.03em;
	}

	.articles-heading span {
		font-family: "JetBrains Mono", monospace;
		font-size: 0.62rem;
		color: #7a8498;
	}

	.article-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 18px;
		margin-top: 24px;
	}

	@media (max-width: 880px) {
		.blog-hero {
			grid-template-columns: 1fr;
			gap: 24px;
		}

		.article-grid {
			grid-template-columns: 1fr 1fr;
		}
	}

	@media (max-width: 580px) {
		.article-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
