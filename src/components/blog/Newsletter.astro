---
const { class: className } = Astro.props;
---

<form class:list={["newsletter-form", className]} method="POST" action="/blog/" name="newsletter" data-netlify="true" netlify>
	<input type="hidden" name="form-name" value="newsletter" />
	<label for="newsletter-email">Project updates, without the noise.</label>
	<p>Occasional Notificator news, release notes, and practical ideas.</p>
	<div>
		<input id="newsletter-email" type="email" name="EMAIL" autocomplete="email" placeholder="Your email" required />
		<button type="submit" aria-label="Subscribe to the Notificator newsletter">Subscribe</button>
	</div>
	<div class="newsletter-status" data-form-status role="status" aria-live="polite" aria-atomic="true" hidden></div>
</form>

<style>
	.newsletter-form > label {
		display: block;
		font-size: 0.92rem;
		font-weight: 720;
		color: white;
	}

	.newsletter-form > p {
		max-width: 360px;
		margin: 6px 0 16px;
		font-size: 0.75rem;
		line-height: 1.55;
		color: #9ca8c3;
	}

	.newsletter-form > div {
		display: flex;
		max-width: 440px;
		gap: 8px;
	}

	.newsletter-form input {
		min-width: 0;
		min-height: 44px;
		flex: 1;
		border: 1px solid rgba(255, 255, 255, 0.16);
		border-radius: 11px;
		background: rgba(255, 255, 255, 0.08);
		padding: 0 14px;
		font: inherit;
		font-size: 0.82rem;
		color: white;
		outline: none;
	}

	.newsletter-form input::placeholder {
		color: #7f8ba7;
	}

	.newsletter-form input:focus {
		border-color: #75a0ff;
		box-shadow: 0 0 0 3px rgba(72, 124, 255, 0.16);
	}

	.newsletter-form button {
		min-height: 44px;
		border: 0;
		border-radius: 11px;
		background: #3475ff;
		padding: 0 16px;
		font: inherit;
		font-size: 0.78rem;
		font-weight: 720;
		color: white;
		cursor: pointer;
	}

	.newsletter-form button:hover {
		background: #4c87ff;
	}

	.newsletter-form button:disabled {
		cursor: wait;
		opacity: 0.7;
	}

	.newsletter-status {
		display: grid;
		grid-template-columns: 32px minmax(0, 1fr);
		align-items: center;
		gap: 10px;
		max-width: 440px;
		margin-top: 10px;
		border: 1px solid transparent;
		border-radius: 12px;
		padding: 11px 12px;
		font-size: 0.72rem;
		font-weight: 650;
		line-height: 1.5;
	}

	.newsletter-status::before {
		display: grid;
		width: 28px;
		height: 28px;
		place-items: center;
		border-radius: 9px;
		font-size: 0.75rem;
		font-weight: 800;
	}

	.newsletter-status[hidden] {
		display: none;
	}

	.newsletter-form[data-form-state="success"] .newsletter-status {
		border-color: rgba(91, 219, 159, 0.25);
		background: linear-gradient(135deg, rgba(31, 190, 119, 0.18), rgba(31, 190, 119, 0.09));
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.07);
		color: #a5f2ca;
	}

	.newsletter-form[data-form-state="success"] .newsletter-status::before {
		background: #27a96d;
		color: white;
		content: "✓";
	}

	.newsletter-form[data-form-state="error"] .newsletter-status {
		border-color: rgba(255, 129, 129, 0.22);
		background: linear-gradient(135deg, rgba(255, 98, 98, 0.17), rgba(255, 98, 98, 0.08));
		color: #ffb3b3;
	}

	.newsletter-form[data-form-state="error"] .newsletter-status::before {
		background: #d05858;
		color: white;
		content: "!";
	}

	@media (max-width: 480px) {
		.newsletter-form > div {
			align-items: stretch;
			flex-direction: column;
		}
	}
</style>

<script>
	import { enhanceNetlifyForm } from "../forms/netlify-form";

	enhanceNetlifyForm(document.querySelector<HTMLFormElement>(".newsletter-form"), {
		pending: "Subscribing…",
		success: "You’re subscribed. The next Notificator update will arrive in your inbox.",
		error: "We couldn’t add you right now. Please try again in a moment.",
	});
</script>
