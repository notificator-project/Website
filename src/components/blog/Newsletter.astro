---
const { class: className } = Astro.props;
---

<form class:list={["newsletter-form", className]} method="POST" action="/blog/" name="newsletter" data-netlify="true" netlify>
	<input type="hidden" name="form-name" value="newsletter" />
	<label for="newsletter-email">Project updates, without the noise.</label>
	<p>Occasional Notificator news, release notes, and practical ideas.</p>
	<div>
		<input id="newsletter-email" type="email" name="EMAIL" autocomplete="email" placeholder="Your email" required />
		<button type="submit" aria-label="Subscribe to the Notificator newsletter">Subscribe</button>
	</div>
</form>

<style>
	.newsletter-form > label {
		display: block;
		font-size: 0.92rem;
		font-weight: 720;
		color: white;
	}

	.newsletter-form > p {
		max-width: 360px;
		margin: 6px 0 16px;
		font-size: 0.75rem;
		line-height: 1.55;
		color: #9ca8c3;
	}

	.newsletter-form > div {
		display: flex;
		max-width: 440px;
		gap: 8px;
	}

	.newsletter-form input {
		min-width: 0;
		min-height: 44px;
		flex: 1;
		border: 1px solid rgba(255, 255, 255, 0.16);
		border-radius: 11px;
		background: rgba(255, 255, 255, 0.08);
		padding: 0 14px;
		font: inherit;
		font-size: 0.82rem;
		color: white;
		outline: none;
	}

	.newsletter-form input::placeholder {
		color: #7f8ba7;
	}

	.newsletter-form input:focus {
		border-color: #75a0ff;
		box-shadow: 0 0 0 3px rgba(72, 124, 255, 0.16);
	}

	.newsletter-form button {
		min-height: 44px;
		border: 0;
		border-radius: 11px;
		background: #3475ff;
		padding: 0 16px;
		font: inherit;
		font-size: 0.78rem;
		font-weight: 720;
		color: white;
		cursor: pointer;
	}

	.newsletter-form button:hover {
		background: #4c87ff;
	}

	@media (max-width: 480px) {
		.newsletter-form > div {
			align-items: stretch;
			flex-direction: column;
		}
	}
</style>
